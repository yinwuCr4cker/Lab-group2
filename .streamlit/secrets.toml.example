# Rename this file to `.streamlit/secrets.toml` locally or add these values
# in Streamlit Cloud's app secrets UI.

SUPABASE_URL = "https://your-project-ref.supabase.co"

# Recommended for this server-side Streamlit app.
# Never put this key in frontend JavaScript, screenshots, GitHub, or chat apps.
SUPABASE_KEY = "your-supabase-service-role-key"

# Telegram bot settings.
# Create a bot with BotFather, then put your bot token and chat ID here.
TELEGRAM_BOT_TOKEN = "123456789:your-telegram-bot-token"
TELEGRAM_CHAT_ID = "123456789"
